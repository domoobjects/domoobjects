{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python Static Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["/tmp/domo_serve.py", "8000"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "Node HTTP Server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "3000", "--cors"],
      "port": 3000
    }
  ]
}
