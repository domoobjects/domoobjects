<script>
function getCart(){try{return JSON.parse(localStorage.getItem('domo_cart'))||[];}catch{return[];}}
function saveCart(c){localStorage.setItem('domo_cart',JSON.stringify(c));window.dispatchEvent(new Event('cartUpdated'));}
function fmtPrice(n){return '₹'+n.toLocaleString('en-IN');}
function openCart(){document.getElementById('cartDrawer').classList.add('open');document.getElementById('cartOverlay').classList.add('open');document.body.style.overflow='hidden';}
function closeCart(){document.getElementById('cartDrawer').classList.remove('open');document.getElementById('cartOverlay').classList.remove('open');document.body.style.overflow='';}
function renderCart(){
  const cart=getCart();
  const body=document.getElementById('cartBody');
  const footer=document.getElementById('cartFooter');
  const empty=document.getElementById('cartEmpty');
  const badge=document.getElementById('cartBadge');
  body.querySelectorAll('.drawer-item').forEach(el=>el.remove());
  if(badge){if(cart.length>0){badge.textContent=cart.length;badge.classList.remove('hidden');}else{badge.classList.add('hidden');}}
  if(cart.length===0){empty.style.display='flex';footer.style.display='none';return;}
  empty.style.display='none';footer.style.display='block';
  let sub=0;
  cart.forEach((item,i)=>{
    sub+=item.price;
    const div=document.createElement('div');
    div.className='drawer-item';
    div.innerHTML=`<div class="drawer-item-img"><img src="${item.img}" alt="${item.name}"/></div><div class="drawer-item-info"><div class="drawer-item-name">${item.name}</div><div class="drawer-item-price">${fmtPrice(item.price)}</div></div><button class="drawer-item-remove" onclick="removeFromCart(${i})" title="Remove">✕</button>`;
    body.insertBefore(div,empty);
  });
  document.getElementById('cartSubtotal').textContent=fmtPrice(sub);
}
function removeFromCart(i){const cart=getCart();cart.splice(i,1);saveCart(cart);renderCart();}
window.addEventListener('cartUpdated',renderCart);
document.addEventListener('DOMContentLoaded',renderCart);
</script>
<!-- ── NOTIFICATION SYSTEM ── -->
<div id="notifStack" style="
  position:fixed;bottom:28px;right:28px;z-index:999;
  display:flex;flex-direction:column-reverse;gap:12px;
  pointer-events:none;
"></div>

<style>
.notif{
  pointer-events:all;
  width:300px;
  background:#0a0a0a;
  border:1px solid #222;
  border-left:3px solid #FF0000;
  padding:14px 16px 14px 16px;
  display:flex;align-items:flex-start;gap:12px;
  transform:translateX(340px);
  opacity:0;
  transition:transform .4s cubic-bezier(.22,1,.36,1), opacity .3s;
  position:relative;
}
.notif.show{transform:translateX(0);opacity:1;}
.notif.hide{transform:translateX(340px);opacity:0;}
.notif-icon{font-size:20px;flex-shrink:0;margin-top:1px;}
.notif-body{flex:1;min-width:0;}
.notif-label{font-family:'Space Mono',monospace;font-size:7.5px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:#FF0000;margin-bottom:3px;}
.notif-title{font-family:'Anton',sans-serif;font-size:15px;color:#fff;text-transform:uppercase;letter-spacing:.03em;line-height:1.1;margin-bottom:4px;}
.notif-sub{font-family:'Space Mono',monospace;font-size:8.5px;color:#666;line-height:1.6;letter-spacing:.03em;}
.notif-link{display:inline-block;margin-top:8px;font-family:'Space Mono',monospace;font-size:8px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#FF0000;text-decoration:none;border-bottom:1px solid rgba(255,0,0,.3);transition:border-color .15s;}
.notif-link:hover{border-color:#FF0000;}
.notif-close{
  position:absolute;top:10px;right:10px;
  background:none;border:none;cursor:pointer;
  font-size:12px;color:#444;
  width:18px;height:18px;
  display:flex;align-items:center;justify-content:center;
  transition:color .15s;line-height:1;padding:0;
}
.notif-close:hover{color:#fff;}
</style>

<script>
const notifications = [
  {
    delay: 1200,
    icon: '📰',
    label: 'New Edition',
    title: 'DOMO Times Vol. XXXVIII',
    sub: 'March 11 edition is live. Objects, manifestos, and one editorial about nothing.',
    link: 'domo-times-mar11.html',
    linkText: 'Read Now →'
  },
  {
    delay: 4000,
    icon: '🔑',
    label: 'Hidden Object',
    title: 'You Found The Key?',
    sub: 'Not listed. Not advertised. Accessible only one way.',
    link: 'handcuff.html',
    linkText: 'Find It →'
  },
  {
    delay: 7500,
    icon: '☀️',
    label: 'New Object',
    title: 'D.O.M.O-042 — The Sun',
    sub: 'Worshipped by every civilisation. Noticed by none of them. ₹222.',
    link: 'sun.html',
    linkText: 'View Object →'
  },
  {
    delay: 12000,
    icon: '🚽',
    label: 'New Object',
    title: 'D.O.M.O-043 — Blue Throne',
    sub: 'The only democratic institution left. For now. ₹444.',
    link: 'blue-toilet.html',
    linkText: 'View Object →'
  }
];

function showNotif(n) {
  const stack = document.getElementById('notifStack');
  const el = document.createElement('div');
  el.className = 'notif';
  el.innerHTML = `
    <div class="notif-icon">${n.icon}</div>
    <div class="notif-body">
      <div class="notif-label">${n.label}</div>
      <div class="notif-title">${n.title}</div>
      <div class="notif-sub">${n.sub}</div>
      <a href="${n.link}" class="notif-link">${n.linkText}</a>
    </div>
    <button class="notif-close" onclick="dismissNotif(this)">✕</button>
  `;
  stack.appendChild(el);
  requestAnimationFrame(()=>requestAnimationFrame(()=>el.classList.add('show')));
  // auto-dismiss after 8s
  setTimeout(()=>dismissNotif(el.querySelector('.notif-close')), 8000);
}

function dismissNotif(btn) {
  const el = btn.closest ? btn.closest('.notif') : btn;
  el.classList.add('hide');
  setTimeout(()=>el.remove(), 400);
}

notifications.forEach(n => setTimeout(()=>showNotif(n), n.delay));
</script>

<script type="module">
import { initNavAuth, auth, signOut } from './firebase.js';
initNavAuth();
window.doSignOut = async () => {
  await signOut(auth);
  window.location.href = 'login.html';
};
</script>

<script>
(function(){
  var logo = document.getElementById('brand-logo-img');
  if(!logo) return;
  var objSection = document.getElementById('objects');
  var aboutSection = document.getElementById('about');

  function updateLogo(){
    if(!objSection || !aboutSection) return;
    var scroll = window.scrollY;
    var objTop = objSection.offsetTop;
    var objBottom = objTop + objSection.offsetHeight;
    var aboutTop = aboutSection.offsetTop;

    // In objects section (white bg) → black logo
    if(scroll + 80 >= objTop && scroll + 80 < objBottom){
      logo.src = logo.dataset.black;
    } else {
      // hero or about/footer (dark bg) → white logo
      logo.src = logo.dataset.white;
    }
  }

  window.addEventListener('scroll', updateLogo, {passive:true});
  updateLogo();
})();
</script>
</body>
