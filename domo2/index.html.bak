<!DOCTYPE html>
<html lang="en">
<head>
<link rel="icon" type="image/png" href="favicon.png">



  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Department of Miscellaneous Objects</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --black: #0a0a0a;
      --white: #f5f5f0;
      --dark-blue: #0a0a0a;
      --mid-blue: #0a0a0a;
      --accent-blue: #FF0000;
      --light-blue: #FF0000;
      --gray: #888;
      --light-gray: #e0e0e0;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Libre Baskerville', serif;
      overflow-x: hidden;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 28px 48px;
      background: linear-gradient(to bottom, rgba(10,10,10,0.85) 0%, transparent 100%);
    }

    .brand {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--white);
      line-height: 1.4;
    }
    .brand span {
      display: block;
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 900;
      letter-spacing: 0.06em;
      line-height: 1;
    }

    .nav-links {
      display: flex;
      gap: 40px;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--white);
      text-decoration: none;
      position: relative;
      opacity: 0.85;
      transition: opacity 0.2s;
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px; left: 0;
      width: 0; height: 1px;
      background: var(--white);
      transition: width 0.3s;
    }
    .nav-links a:hover { opacity: 1; }
    .nav-links a:hover::after { width: 100%; }

    /* ─── HERO ─── */
    #home {
      position: relative;
      width: 100%; height: 100vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(135deg, rgba(13,27,42,0.72) 0%, rgba(10,10,10,0.55) 50%, rgba(13,27,42,0.8) 100%),
        url('data:image/png;base64,') center/cover no-repeat;
      transform: scale(1.04);
      animation: heroZoom 18s ease-in-out infinite alternate;
    }
    @keyframes heroZoom {
      from { transform: scale(1.04); }
      to   { transform: scale(1.12); }
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center bottom, rgba(13,27,42,0.45) 0%, transparent 70%);
    }

    .hero-content {
      position: relative;
      text-align: center;
      padding: 0 24px;
      animation: fadeUp 1.2s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(36px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-eyebrow {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--light-blue);
      margin-bottom: 18px;
      opacity: 0.9;
    }
    .hero-title {
      font-family: 'Bahianita', sans-serif;
      font-size: clamp(36px, 5.5vw, 78px);
      font-weight: 400;
      line-height: 0.78;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 6px;
    }
    .hero-title em {
      font-style: normal;
      color: var(--white);
      display: block;
    }
    .hero-subtitle {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(245,245,240,0.6);
      margin-top: 22px;
    }
    .hero-scroll {
      position: absolute;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      opacity: 0.5;
      animation: bounce 2s ease-in-out infinite;
    }
    @keyframes bounce {
      0%,100% { transform: translateX(-50%) translateY(0); }
      50%      { transform: translateX(-50%) translateY(8px); }
    }
    .hero-scroll span {
      font-family: 'Space Mono', monospace;
      font-size: 9px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
    }
    .hero-scroll-line {
      width: 1px; height: 40px;
      background: linear-gradient(to bottom, var(--white), transparent);
    }

    
    /* ─── OBJECTS SECTION ─── */
    #objects {
      background: #ffffff;
      padding: 20px 40px 60px;
    }

    .objects-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      max-width: 1100px;
      margin: 0 auto;
    }

    .object-card {
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 28px 24px;
      cursor: pointer;
      transition: transform 0.3s ease;
    }
    .object-card:hover {
      transform: scale(1.06);
    }
    .object-card img {
      width: 100%;
      max-width: 180px;
      height: 180px;
      object-fit: contain;
      display: block;
      background: transparent;
    }

    .object-card-link { display: block; text-decoration: none; }

    /* ─── ABOUT ─── */
    #about {
      background: var(--dark-blue);
      color: var(--white);
      padding: 100px 48px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      min-height: 80vh;
    }

    .about-text {}
    .about-eyebrow {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--light-blue);
      margin-bottom: 20px;
    }
    .about-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(36px, 4vw, 58px);
      font-weight: 900;
      line-height: 1.05;
      margin-bottom: 28px;
      color: var(--white);
    }
    .about-title em {
      font-style: italic;
      color: var(--light-blue);
    }
    .about-body {
      font-size: 15px;
      line-height: 1.85;
      color: rgba(245,245,240,0.75);
      max-width: 480px;
    }
    .about-body p + p { margin-top: 18px; }

    .about-visual {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    /* Octopus SVG illustration */
    .octopus-wrap {
      width: 340px;
      height: 340px;
      position: relative;
    }
    .octopus-wrap svg {
      width: 100%;
      height: 100%;
      opacity: 0.92;
      animation: float 6s ease-in-out infinite;
      filter: drop-shadow(0 0 40px rgba(255,0,0,0.4));
    }
    @keyframes float {
      0%,100% { transform: translateY(0) rotate(-2deg); }
      50%      { transform: translateY(-18px) rotate(2deg); }
    }

    .about-deco-ring {
      position: absolute;
      inset: -30px;
      border-radius: 50%;
      border: 1px solid rgba(200,216,232,0.12);
      animation: spin 40s linear infinite;
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    /* ─── FOOTER ─── */
    footer {
      background: var(--black);
      padding: 50px 48px 36px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .footer-brand {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      line-height: 1.6;
    }
    .footer-brand strong {
      display: block;
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 900;
      color: rgba(255,255,255,0.8);
      letter-spacing: 0.05em;
    }
    .footer-links {
      display: flex;
      gap: 28px;
    }
    .footer-links a {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--white); }

    /* Responsive */
    @media (max-width: 900px) {
      .objects-grid { grid-template-columns: repeat(2, 1fr); }
      #about { grid-template-columns: 1fr; gap: 48px; }
      nav { padding: 20px 24px; }
      .hero-title { font-size: 52px; }
    }
    @media (max-width: 600px) {
      .objects-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
      #objects { padding: 60px 20px; }
      nav { padding: 16px 20px; }
      .nav-links { gap: 20px; }
    }
  
.cart-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:900;opacity:0;pointer-events:none;transition:opacity .3s;}
.cart-overlay.open{opacity:1;pointer-events:all;}
.cart-drawer{position:fixed;top:0;right:0;bottom:0;width:420px;max-width:95vw;background:#fff;z-index:901;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;border-left:3px solid #0a0a0a;}
.cart-drawer.open{transform:translateX(0);}
.cart-header{display:flex;align-items:center;justify-content:space-between;padding:24px 28px;border-bottom:3px solid #0a0a0a;flex-shrink:0;}
.cart-header-title{font-family:'Playfair Display',serif;font-size:26px;font-weight:900;}
.cart-close{background:none;border:2px solid #0a0a0a;width:36px;height:36px;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;transition:background .15s,color .15s;}
.cart-close:hover{background:#0a0a0a;color:#fff;}
.cart-body{flex:1;overflow-y:auto;padding:0 28px;}
.cart-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:12px;text-align:center;}
.cart-empty .empty-big{font-family:'Playfair Display',serif;font-size:44px;font-weight:900;color:#e0e0e0;}
.cart-empty .empty-sm{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:#ccc;}
.drawer-item{display:flex;gap:14px;padding:18px 0;border-bottom:1px solid #e8e8e8;align-items:center;}
.drawer-item-img{width:58px;height:58px;border:2px solid #e8e8e8;background:#f8f8f8;display:flex;align-items:center;justify-content:center;padding:7px;flex-shrink:0;}
.drawer-item-img img{width:100%;height:100%;object-fit:contain;}
.drawer-item-info{flex:1;min-width:0;}
.drawer-item-name{font-family:'Playfair Display',serif;font-size:14px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.drawer-item-price{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;margin-top:3px;}
.drawer-item-remove{background:none;border:none;cursor:pointer;font-size:14px;color:#ccc;transition:color .15s;flex-shrink:0;}
.drawer-item-remove:hover{color:#FF0000;}
.cart-footer{padding:20px 28px;border-top:3px solid #0a0a0a;flex-shrink:0;}
.cart-subtotal{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;}
.cart-subtotal .lbl{font-family:'Space Mono',monospace;font-size:9px;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:#666;}
.cart-subtotal .val{font-family:'Playfair Display',serif;font-size:20px;font-weight:900;}
.btn-checkout{display:block;background:#0a0a0a;color:#fff;border:none;padding:16px;font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;width:100%;transition:background .15s;text-align:center;text-decoration:none;}
.btn-checkout:hover{background:#0a0a0a;}
.nav-cart-btn{background:none;border:2px solid rgba(245,245,240,.3);padding:7px 14px;cursor:pointer;font-family:'Space Mono',monospace;font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#f5f5f0;display:flex;align-items:center;gap:8px;transition:background .15s,border-color .15s;position:relative;}
.nav-cart-btn:hover{background:rgba(245,245,240,.1);border-color:rgba(245,245,240,.6);}
.cart-badge{background:#FF0000;color:#0a0a0a;border-radius:50%;width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;font-family:'Space Mono',monospace;position:absolute;top:-8px;right:-8px;}
.cart-badge.hidden{display:none;}


/* ── DOMO NAV AVATAR ── */
.nav-avatar-btn{cursor:pointer;display:flex;align-items:center;}
.nav-avatar-circle{width:30px;height:30px;border-radius:50%;background:var(--accent,#e82010);display:flex;align-items:center;justify-content:center;font-family:"Space Mono",monospace;font-size:11px;font-weight:700;color:#fff;border:1.5px solid rgba(255,255,255,.2);transition:box-shadow .2s;}
.nav-avatar-circle:hover{box-shadow:0 0 0 3px rgba(255,255,255,.15);}
.nav-dropdown{display:none;flex-direction:column;position:absolute;top:calc(100% + 10px);right:0;min-width:200px;background:#0a0a0a;border:1px solid rgba(255,255,255,.1);z-index:500;padding:0;}
.nav-dropdown-top{padding:14px 16px 10px;border-bottom:1px solid rgba(255,255,255,.07);}
.nav-avatar-name{font-family:"Anton",sans-serif;font-size:15px;color:#fff;text-transform:uppercase;letter-spacing:.03em;}
.nav-avatar-email{font-family:"Space Mono",monospace;font-size:8px;color:rgba(255,255,255,.35);letter-spacing:.05em;margin-top:2px;word-break:break-all;}
.nav-dd-link{display:block;padding:11px 16px;font-family:"Space Mono",monospace;font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.6);text-decoration:none;transition:background .15s,color .15s;border-bottom:1px solid rgba(255,255,255,.05);}
.nav-dd-link:hover{background:rgba(255,255,255,.06);color:#fff;}
.nav-dd-signout{display:block;width:100%;padding:11px 16px;font-family:"Space Mono",monospace;font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,80,60,.7);background:none;border:none;cursor:pointer;text-align:left;transition:background .15s,color .15s;}
.nav-dd-signout:hover{background:rgba(255,60,40,.08);color:#ff4030;}

.brand{text-decoration:none;display:flex;align-items:center;}
.brand-logo{height:58px;width:auto;display:block;}
</style>
</head>
<body>

<div class="cart-overlay" id="cartOverlay" onclick="closeCart()"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-header">
    <div class="cart-header-title">Your Cart</div>
    <button class="cart-close" onclick="closeCart()">✕</button>
  </div>
  <div class="cart-body" id="cartBody">
    <div class="cart-empty" id="cartEmpty">
      <div class="empty-big">Empty</div>
      <div class="empty-sm">Browse the objects to add items</div>
    </div>
  </div>
  <div class="cart-footer" id="cartFooter" style="display:none">
    <div class="cart-subtotal">
      <span class="lbl">Subtotal</span>
      <span class="val" id="cartSubtotal">₹0</span>
    </div>
    <a href="checkout.html" class="btn-checkout">Proceed to Checkout →</a>
  </div>
</div>


  <!-- NAV -->
  <nav>
<a href="index.html" class="brand"><img id="brand-logo-img" data-white="data:image/png;base64," data-black="data:image/png;base64," src="data:image/png;base64," alt="DOMO" class="brand-logo"/></a>
    <ul class="nav-links">
      <li><a href="#home">Home</a></li>
      <li><a href="#objects">Objects</a></li>
      <li id="navLoginLink"><a href="login.html">Login</a></li><li id="navAvatar" style="display:none;position:relative;" onmouseenter="clearTimeout(window._ddT);this.querySelector('.nav-dropdown').style.display='flex'" onmouseleave="window._ddT=setTimeout(()=>this.querySelector('.nav-dropdown').style.display='none',320)" ondblclick="window.location.href='profile.html'"><div class="nav-avatar-btn"><div class="nav-avatar-circle"><span class="nav-avatar-initial">?</span></div></div><div class="nav-dropdown"><div class="nav-dropdown-top"><div class="nav-avatar-name">Name</div><div class="nav-avatar-email">email</div></div><a href="profile.html" class="nav-dd-link">&#9654; My Profile</a><button class="nav-dd-signout" onclick="doSignOut()">Sign Out</button></div></li>
      <li><a href="domo-times.html" style="border:1.5px solid currentColor;padding:3px 10px;letter-spacing:.15em;">DOMO Times</a></li>
    </ul>
  
  <button class="nav-cart-btn" onclick="openCart()">Cart <span class="cart-badge hidden" id="cartBadge">0</span></button>
</nav>

  <!-- HERO -->
