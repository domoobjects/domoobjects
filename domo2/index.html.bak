        <a href="mantel-clock.html" style="text-decoration:none;display:block;"><div class="object-card"><img src="data:image/svg+xml;base64," alt="Mantel Clock"/></div></a>
        <a href="antique-frame.html" style="text-decoration:none;display:block;"><div class="object-card"><img src="data:image/svg+xml;base64," alt="Antique Frame"/></div></a>
        <a href="cast-iron-kettle.html" style="text-decoration:none;display:block;"><div class="object-card"><img src="data:image/svg+xml;base64," alt="Cast Iron Kettle"/></div></a>
