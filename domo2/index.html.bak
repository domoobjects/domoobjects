    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Est. 2024 — Curated Curiosities</p>
      <h1 class="hero-title">
        Department of<br><em>Miscellaneous</em><br>Objects
      </h1>
      <p class="hero-subtitle">DOMO — Every Object Has a Story</p>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="hero-scroll-line"></div>
    </div>
  </section>

